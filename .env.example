# Copy to .env and fill in your values. Never commit .env to source control.

# --- Snowflake (required) ---
SNOWFLAKE_ACCOUNT=myorg-myaccount   # e.g. xy12345.us-east-1
SNOWFLAKE_USER=pipeline_user
SNOWFLAKE_PASSWORD=changeme

# --- Snowflake (optional, defaults shown) ---
SNOWFLAKE_DATABASE=IOWA_LIQUOR
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# --- Socrata API (optional but strongly recommended) ---
# Without a token you're limited to 1000 requests/day (unauthenticated throttle).
# Register free at https://data.iowa.gov/profile/app_tokens
SOCRATA_APP_TOKEN=

# --- Pipeline tuning (optional) ---
BATCH_SIZE=10000          # records per API page / Snowflake upsert batch
MAX_RETRIES=3
RETRY_DELAY=5.0           # seconds (exponential backoff multiplier)

# --- Alerting (optional) ---
# Slack incoming webhook URL — leave blank to disable alerts
ALERT_WEBHOOK_URL=
